{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "node -e \"require('fs').writeFileSync('frontend/static/config.js', 'window.AEGIS_API_BASE=' + JSON.stringify(process.env.AEGIS_API_BASE || ''))\"",
  "outputDirectory": "frontend",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/static/landing.html" },
    { "source": "/landing", "destination": "/static/landing.html" },
    { "source": "/app", "destination": "/static/index.html" }
  ]
}
