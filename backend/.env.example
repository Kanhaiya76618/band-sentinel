# ── Aegis environment ───────────────────────────────────────────────────────
# Offline demo needs NONE of these. Fill them in only for the live run.

# Which LLM path to use: offline | aiml | featherless
LLM_MODE=offline

# Which bus: local | band
BUS=local

# ── Auth (demo-grade sign-in, Phase 7) ──────────────────────────────────────
# Passwords are pbkdf2-hashed in SQLite; sessions are httpOnly cookies. Optional:
AEGIS_SESSION_DAYS=7          # session cookie lifetime (days)

# ── AI/ML API  (observer / remediator / commander) ──────────────────────────
# Targets the "Best Use of AI/ML API" prize.
AIML_API_KEY=
AIML_BASE_URL=https://api.aimlapi.com/v1
AIML_MODEL=gpt-4o-mini

# ── Featherless AI  (diagnostician / validator) ─────────────────────────────
# Targets the "Best Use of Featherless AI" prize.
# CONFIRM base_url + a current model id from the Featherless setup guide.
FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct

# ── Band  (the shared agent room) ───────────────────────────────────────────
# Custom REST + Phoenix-Channels integration (band-sdk). Identity is PER AGENT:
# register 5 remote agents in Band, add all 5 to ONE shared chat, then set each
# agent's id + key below and the shared chat id. Activate with BUS=band.
BAND_CHAT_ID=
BAND_OBSERVER_ID=
BAND_OBSERVER_KEY=
BAND_DIAGNOSTICIAN_ID=
BAND_DIAGNOSTICIAN_KEY=
BAND_REMEDIATOR_ID=
BAND_REMEDIATOR_KEY=
BAND_VALIDATOR_ID=
BAND_VALIDATOR_KEY=
BAND_COMMANDER_ID=
BAND_COMMANDER_KEY=
# Optional — the human participant's id, so commander approval requests ping the
# human directly. If unset, BandBus still satisfies Band's "≥1 mention" rule by
# falling back to the sending agent's own id (no side effects).
BAND_HUMAN_ID=
# Optional — REST base for your Band instance (default is the band-sdk default):
BAND_REST_URL=https://app.band.ai

# ── Email: incident reports (Phase 2) ───────────────────────────────────────
# Primary path = Resend (set RESEND_API_KEY). SMTP is the fallback if no
# Resend key is present. Configure ONE of the two blocks below.
# Resend (https://resend.com) — single key, verified from-address:
RESEND_API_KEY=
# Resend FREE tier (no verified domain) can ONLY send to your own verified email.
# Set it here so Aegis can warn clearly before a non-verified recipient is rejected
# (resume-to-self always works; use SMTP or a verified domain to reach others).
RESEND_VERIFIED_EMAIL=
# SMTP fallback (e.g. Gmail app-password, Mailgun):
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Shared by both paths:
EMAIL_FROM=
EMAIL_TO=

# ── Job search: Adzuna free API (Phase 3) ───────────────────────────────────
# Get a free app id + key at https://developer.adzuna.com (no card required).
JOB_PROVIDER=adzuna           # only 'adzuna' implemented today
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=gb             # gb | us | … (Adzuna country code)

# ── Channels: multi-platform interface (Phase 6) ────────────────────────────
# Each channel stays DISABLED with a clear status until its keys are set.
# Public-facing deep links use this base URL:
AEGIS_PUBLIC_URL=http://127.0.0.1:8000

# Telegram — FULL loop (send + inline Approve/Reject via long-poll). @BotFather.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord — notify + post. Use a webhook URL, OR a bot token + channel id.
DISCORD_WEBHOOK_URL=
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# WhatsApp via Twilio sandbox — notify (reply-approval needs a public webhook
# pointed at /api/channels/whatsapp/inbound).
TWILIO_SID=
TWILIO_AUTH=
TWILIO_WHATSAPP_FROM=         # e.g. +14155238886 (Twilio sandbox number)
TWILIO_WHATSAPP_TO=           # your verified WhatsApp number

# LinkedIn — share/draft ONLY (search + auto-apply are forbidden by the API).
# Obtain LINKEDIN_ACCESS_TOKEN via the OAuth flow (client id/secret drive it).
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=          # optional; else resolved from /v2/me
