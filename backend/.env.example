# ── Aegis environment ───────────────────────────────────────────────────────
# Offline demo needs NONE of these. Fill them in only for the live run.

# Which LLM path to use: offline | aiml | featherless
LLM_MODE=offline

# Which bus: local | band
BUS=local

# ── AI/ML API  (observer / remediator / commander) ──────────────────────────
# Targets the "Best Use of AI/ML API" prize.
AIML_API_KEY=
AIML_BASE_URL=https://api.aimlapi.com/v1
AIML_MODEL=gpt-4o-mini

# ── Featherless AI  (diagnostician / validator) ─────────────────────────────
# Targets the "Best Use of Featherless AI" prize.
# CONFIRM base_url + a current model id from the Featherless setup guide.
FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct

# ── Band  (the shared agent room) ───────────────────────────────────────────
# Fill BandBus in backend/bus.py from the Band Agent API docs, then set:
BAND_API_KEY=
BAND_ROOM_ID=
